{
  "name": "hellowee",
  "version": "2.0.0",
  "description": "멀티플레이어 시메지 데스크톱 앱 (Live2D)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "build": "electron-builder"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "electron-store": "^8.1.0",
    "express": "^4.18.2",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^7.3.3",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.hellowee.app",
    "productName": "Hellowee",
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "extraResources": [
      {
        "from": "models",
        "to": "models",
        "filter": ["**/*"]
      }
    ]
  }
}
